---
import BaseLayout from "../layouts/BaseLayout.astro";
import { type TagDto } from "../models/dtos/TagDto";
import { PocketBaseCollections } from "../models/PocketBase";

const { pb } = Astro.locals;

const tags = await pb
  .collection<TagDto>(PocketBaseCollections.TAGS)
  .getFullList();
---

<BaseLayout title="Gallery">
  <h1>Astro Gallery 🚀</h1>
  <p>Welcome to my gallery, you can find some pictures here</p>

  <h2>Liste des tags</h2>
  <ul>
    {tags.map((tag) => <li>{tag.label}</li>)}
  </ul>
</BaseLayout>
